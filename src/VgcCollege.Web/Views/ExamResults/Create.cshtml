@model VgcCollege.Web.Models.ExamResult

@{
    ViewData["Title"] = "Create Result";
}

<h1>Add Exam Result</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="ExamId">Exam</label>
                <select asp-for="ExamId" class="form-control" asp-items="ViewBag.ExamId">
                    <option value="">-- Select Exam --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId">Student</label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId">
                    <option value="">-- Select Student --</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Score"></label>
                <input asp-for="Score" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label asp-for="Grade"></label>
                <input asp-for="Grade" class="form-control" placeholder="A, B, C..." />
            </div>

            <button type="submit" class="btn btn-primary">Save</button>
            <a asp-action="Index" class="btn btn-secondary">Back</a>
        </form>
    </div>
</div>