@model VgcCollege.Web.Models.ExamResult

@{
    ViewData["Title"] = "Result Details";
    var released = Model.Exam?.ResultsReleased == true;
}

<h1>Exam Result Details</h1>

<div>
    <dl class="row">
        <dt class="col-sm-3">Student</dt>
        <dd class="col-sm-9">@Model.StudentProfile?.Name</dd>

        <dt class="col-sm-3">Exam</dt>
        <dd class="col-sm-9">@Model.Exam?.Title</dd>

        <dt class="col-sm-3">Course</dt>
        <dd class="col-sm-9">@Model.Exam?.Course?.Name</dd>

        <dt class="col-sm-3">Score</dt>
        <dd class="col-sm-9">@Model.Score</dd>

        <dt class="col-sm-3">Grade</dt>
        <dd class="col-sm-9">@Model.Grade</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">
            @(released ? "Released" : "Provisional")
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>