@model VgcCollege.Web.Models.FacultyProfile

@{
    ViewData["Title"] = "Faculty Details";
    var courses = ViewBag.Courses as List<VgcCollege.Web.Models.Course> ?? new List<VgcCollege.Web.Models.Course>();
    var branches = ViewBag.Branches as List<string> ?? new List<string>();
}

<h1>Faculty Details</h1>

<div>
    <h4>Faculty Profile</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">User Email</dt>
        <dd class="col-sm-9">@(Model.IdentityUser?.Email ?? "No linked user")</dd>

        <dt class="col-sm-3">Phone</dt>
        <dd class="col-sm-9">@Model.Phone</dd>

        <dt class="col-sm-3">Total Courses</dt>
        <dd class="col-sm-9">@courses.Count</dd>

        <dt class="col-sm-3">Total Branches</dt>
        <dd class="col-sm-9">@branches.Count</dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Assigned Courses</h4>

    @if (courses.Any())
    {
        <ul>
            @foreach (var course in courses)
            {
                <li>
                    @course.Name
                    -
                    @(course.Branch?.Name ?? "No branch")
                    (@course.StartDate.ToString("dd/MM/yyyy") - @course.EndDate.ToString("dd/MM/yyyy"))
                </li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">No courses assigned to this faculty member.</p>
    }
</div>

<div class="mt-4">
    <h4>Branches</h4>

    @if (branches.Any())
    {
        <ul>
            @foreach (var branch in branches)
            {
                <li>@branch</li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">No branches linked through course assignments.</p>
    }
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>