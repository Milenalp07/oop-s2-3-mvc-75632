@model VgcCollege.Web.Models.FacultyProfile

@{
    ViewData["Title"] = "Create Lecturer";
}

<h1>Create Lecturer</h1>

<h4>Faculty Profile</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="Name" class="control-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="IdentityUserId" class="control-label">User</label>
                <select asp-for="IdentityUserId" class="form-control" asp-items="ViewBag.IdentityUserId">
                    <option value="">-- Select User --</option>
                </select>
                <span asp-validation-for="IdentityUserId" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Create</button>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}