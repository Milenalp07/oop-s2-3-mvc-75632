@using Microsoft.AspNetCore.Identity
@using VgcCollege.Web.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VgcCollege</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VgcCollege.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">VgcCollege</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav me-auto mb-2 mb-sm-0">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">Dashboard</a>
                            </li>

                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentProfiles" asp-action="Index">Students</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="FacultyProfiles" asp-action="Index">Lecturers</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Branches" asp-action="Index">Branches</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="CourseEnrolments" asp-action="Index">Enrolments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AttendanceRecords" asp-action="Index">Attendance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AssignmentResults" asp-action="Index">Results</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                                </li>
                            }
                            else if (User.IsInRole("Faculty"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Courses" asp-action="Index">Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="CourseEnrolments" asp-action="Index">Enrolments</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AttendanceRecords" asp-action="Index">Attendance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="AssignmentResults" asp-action="Index">Results</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Exams" asp-action="Index">Exams</a>
                                </li>
                            }
                            else if (User.IsInRole("Student"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentPortal" asp-action="Index">My Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentPortal" asp-action="MyCourses">My Courses</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentPortal" asp-action="MyAttendance">My Attendance</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentPortal" asp-action="MyResults">My Results</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="StudentPortal" asp-action="MyExams">My Exams</a>
                                </li>
                            }
                        }
                    </ul>

                    <ul class="navbar-nav">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <li class="nav-item d-flex align-items-center me-2 text-white">
                                Hello, @User.Identity?.Name
                            </li>
                            <li class="nav-item">
                                <form asp-area="Identity" asp-page="/Account/Logout" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-light">Logout</button>
                                </form>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container pb-3">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - VgcCollege - Academic Management System
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>