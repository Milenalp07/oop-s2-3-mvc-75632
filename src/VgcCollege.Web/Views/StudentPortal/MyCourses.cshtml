@model IEnumerable<VgcCollege.Web.Models.CourseEnrolment>

@{
    ViewData["Title"] = "My Courses";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body">
            <h1 class="mb-2">My Courses</h1>
            <p class="text-muted mb-0">View all courses linked to your student account.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Course</th>
                                <th>Start Date</th>
                                <th>End Date</th>
                                <th>Branch</th>
                                <th>Enrol Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.Course?.Name</td>
                                    <td>@item.Course?.StartDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Course?.EndDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Course?.Branch?.Name</td>
                                    <td>@item.EnrolDate.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Status</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No courses found for your account.
                </div>
            }
        </div>
    </div>
</div>