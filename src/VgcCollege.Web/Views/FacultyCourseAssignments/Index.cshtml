@model IEnumerable<VgcCollege.Web.Models.FacultyCourseAssignment>

@{
    ViewData["Title"] = "Faculty Course Assignments";
}

<h1>Faculty Course Assignments</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Assignment</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Lecturer</th>
            <th>User Email</th>
            <th>Course</th>
            <th>Branch</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@(item.FacultyProfile?.Name ?? "No lecturer")</td>
                <td>@(item.FacultyProfile?.IdentityUser?.Email ?? "No linked user")</td>
                <td>@(item.Course?.Name ?? "No course")</td>
                <td>@(item.Course?.Branch?.Name ?? "No branch")</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>