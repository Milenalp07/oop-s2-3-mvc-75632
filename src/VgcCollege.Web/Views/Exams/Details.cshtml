@model VgcCollege.Web.Models.Exam

@{
    ViewData["Title"] = "Exam Details";
}

<h1>Exam Details</h1>

<div>
    <h4>Exam</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Title</dt>
        <dd class="col-sm-9">@Model.Title</dd>

        <dt class="col-sm-3">Course</dt>
        <dd class="col-sm-9">@Model.Course?.Name</dd>

        <dt class="col-sm-3">Branch</dt>
        <dd class="col-sm-9">@Model.Course?.Branch?.Name</dd>

        <dt class="col-sm-3">Date</dt>
        <dd class="col-sm-9">@Model.Date.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-3">Max Score</dt>
        <dd class="col-sm-9">@Model.MaxScore</dd>

        <dt class="col-sm-3">Results</dt>
        <dd class="col-sm-9">
            @(Model.ResultsReleased ? "Released" : "Provisional")
        </dd>
    </dl>
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back</a>
</div>