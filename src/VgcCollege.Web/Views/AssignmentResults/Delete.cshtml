@model VgcCollege.Web.Models.AssignmentResult

@{
    ViewData["Title"] = "Delete Assignment Result";
}

<h1>Delete Assignment Result</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Assignment Result</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Assignment</dt>
        <dd class="col-sm-10">@(Model.Assignment?.Title ?? "")</dd>

        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">@(Model.CourseEnrolment?.StudentProfile?.Name ?? "")</dd>

        <dt class="col-sm-2">Marks</dt>
        <dd class="col-sm-10">@Model.Marks</dd>

        <dt class="col-sm-2">Feedback</dt>
        <dd class="col-sm-10">@Model.Feedback</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </form>
</div>