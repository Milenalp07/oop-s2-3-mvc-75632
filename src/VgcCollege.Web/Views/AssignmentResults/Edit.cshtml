@model VgcCollege.Web.Models.AssignmentResult

@{
    ViewData["Title"] = "Edit Assignment Result";
}

<h1>Edit Assignment Result</h1>

<h4>Assignment Result</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="AssignmentId" class="control-label"></label>
                <select asp-for="AssignmentId" class="form-control" asp-items="ViewBag.AssignmentId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CourseEnrolmentId" class="control-label"></label>
                <select asp-for="CourseEnrolmentId" class="form-control" asp-items="ViewBag.CourseEnrolmentId"></select>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Marks" class="control-label"></label>
                <input asp-for="Marks" class="form-control" />
                <span asp-validation-for="Marks" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Feedback" class="control-label"></label>
                <textarea asp-for="Feedback" class="form-control"></textarea>
                <span asp-validation-for="Feedback" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}