@model IEnumerable<VgcCollege.Web.Models.StudentProfile>

@{
    ViewData["Title"] = "Student Profiles";
    var enrolmentMap = ViewBag.EnrolmentMap as Dictionary<int, List<string>> ?? new Dictionary<int, List<string>>();
}

<h1>Student Profiles</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th>Address</th>
            <th>Student Number</th>
            <th>DOB</th>
            <th>Course</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var courses = enrolmentMap.ContainsKey(item.Id)
                ? enrolmentMap[item.Id]
                : new List<string>();

            <tr>
                <td>@item.Name</td>
                <td>@item.Email</td>
                <td>@item.Phone</td>
                <td>@item.Address</td>
                <td>@item.StudentNumber</td>
                <td>@(item.DOB?.ToString("dd/MM/yyyy") ?? "")</td>
                <td>
                    @if (courses.Any())
                    {
                        @string.Join(", ", courses)
                    }
                    else
                    {
                        <span class="text-muted">Not enrolled</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>