@model VgcCollege.Web.Models.CourseEnrolment

@{
    ViewData["Title"] = "Create Enrolment";
}

<h1>Create Enrolment</h1>

<h4>Course Enrolment</h4>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="form-group mb-3">
                <label asp-for="StudentProfileId" class="control-label"></label>
                <select asp-for="StudentProfileId" class="form-control" asp-items="ViewBag.StudentProfileId">
                    <option value="">-- Select Student --</option>
                </select>
                <span asp-validation-for="StudentProfileId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="CourseId" class="control-label"></label>
                <select asp-for="CourseId" class="form-control" asp-items="ViewBag.CourseId">
                    <option value="">-- Select Course --</option>
                </select>
                <span asp-validation-for="CourseId" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="EnrolDate" class="control-label"></label>
                <input asp-for="EnrolDate" class="form-control" />
                <span asp-validation-for="EnrolDate" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Status" class="control-label"></label>
                <select asp-for="Status" class="form-control">
                    <option>Active</option>
                    <option>Completed</option>
                    <option>Withdrawn</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}