@model VgcCollege.Web.Models.AttendanceRecord

@{
    ViewData["Title"] = "Delete Attendance";
}

<h1>Delete Attendance</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Attendance Record</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Student</dt>
        <dd class="col-sm-10">
            @(Model.CourseEnrolment?.StudentProfile?.Name ?? "No Student")
        </dd>

        <dt class="col-sm-2">Course</dt>
        <dd class="col-sm-10">
            @(Model.CourseEnrolment?.Course?.Name ?? "No Course")
        </dd>

        <dt class="col-sm-2">Week</dt>
        <dd class="col-sm-10">
            @Model.WeekNumber
        </dd>

        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">
            @Model.Date.ToShortDateString()
        </dd>

        <dt class="col-sm-2">Present</dt>
        <dd class="col-sm-10">
            @(Model.Present ? "Yes" : "No")
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>