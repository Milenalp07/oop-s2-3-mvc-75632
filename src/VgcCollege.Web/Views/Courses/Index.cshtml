@model IEnumerable<VgcCollege.Web.Models.Course>

@{
    ViewData["Title"] = "Courses";
    var studentCountMap = ViewBag.StudentCountMap as Dictionary<int, int> ?? new Dictionary<int, int>();
    var lecturerCountMap = ViewBag.LecturerCountMap as Dictionary<int, int> ?? new Dictionary<int, int>();
}

<h1>Courses</h1>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">
        @TempData["ErrorMessage"]
    </div>
}

@if (User.IsInRole("Admin"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New Course</a>
    </p>
}

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Name</th>
            <th>Branch</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Students</th>
            <th>Lecturers</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var studentCount = studentCountMap.ContainsKey(item.Id) ? studentCountMap[item.Id] : 0;
            var lecturerCount = lecturerCountMap.ContainsKey(item.Id) ? lecturerCountMap[item.Id] : 0;

            var status = DateTime.Today < item.StartDate
                ? "Upcoming"
                : DateTime.Today > item.EndDate
                    ? "Completed"
                    : "Active";

            <tr>
                <td>@item.Name</td>
                <td>@(item.Branch?.Name ?? "No branch")</td>
                <td>@item.StartDate.ToString("dd/MM/yyyy")</td>
                <td>@item.EndDate.ToString("dd/MM/yyyy")</td>
                <td>@studentCount</td>
                <td>@lecturerCount</td>
                <td>@status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <text> | </text>
                        <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                        <text> | </text>
                        <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>