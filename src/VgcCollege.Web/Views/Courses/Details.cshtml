@model VgcCollege.Web.Models.Course

@{
    ViewData["Title"] = "Course Details";
    var students = ViewBag.Students as List<string> ?? new List<string>();
    var lecturers = ViewBag.Lecturers as List<string> ?? new List<string>();

    var status = DateTime.Today < Model.StartDate
        ? "Upcoming"
        : DateTime.Today > Model.EndDate
            ? "Completed"
            : "Active";
}

<h1>Course Details</h1>

<div>
    <h4>Course</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Branch</dt>
        <dd class="col-sm-9">@(Model.Branch?.Name ?? "No branch")</dd>

        <dt class="col-sm-3">Start Date</dt>
        <dd class="col-sm-9">@Model.StartDate.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-3">End Date</dt>
        <dd class="col-sm-9">@Model.EndDate.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@status</dd>

        <dt class="col-sm-3">Total Students</dt>
        <dd class="col-sm-9">@students.Count</dd>

        <dt class="col-sm-3">Total Lecturers</dt>
        <dd class="col-sm-9">@lecturers.Count</dd>
    </dl>
</div>

<div class="mt-4">
    <h4>Enrolled Students</h4>

    @if (students.Any())
    {
        <ul>
            @foreach (var student in students.OrderBy(s => s))
            {
                <li>@student</li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">No students enrolled in this course.</p>
    }
</div>

<div class="mt-4">
    <h4>Assigned Lecturers</h4>

    @if (lecturers.Any())
    {
        <ul>
            @foreach (var lecturer in lecturers.OrderBy(l => l))
            {
                <li>@lecturer</li>
            }
        </ul>
    }
    else
    {
        <p class="text-muted">No lecturers assigned to this course.</p>
    }
</div>

<div class="mt-3">
    @if (User.IsInRole("Admin"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
    }
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>