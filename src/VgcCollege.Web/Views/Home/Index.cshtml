@model VgcCollege.Web.Models.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold">VGC College Dashboard</h1>
        <p class="text-muted">Overview of the academic management system</p>
    </div>

    <div class="row g-4">
        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 text-center h-100">
                <div class="card-body">
                    <h5 class="card-title text-primary">Students</h5>
                    <h2 class="fw-bold">@Model.TotalStudents</h2>
                    <p class="text-muted mb-0">Registered students</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 text-center h-100">
                <div class="card-body">
                    <h5 class="card-title text-success">Courses</h5>
                    <h2 class="fw-bold">@Model.TotalCourses</h2>
                    <p class="text-muted mb-0">Available courses</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 text-center h-100">
                <div class="card-body">
                    <h5 class="card-title text-warning">Lecturers</h5>
                    <h2 class="fw-bold">@Model.TotalLecturers</h2>
                    <p class="text-muted mb-0">Academic staff</p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-3">
            <div class="card shadow-sm border-0 text-center h-100">
                <div class="card-body">
                    <h5 class="card-title text-danger">Branches</h5>
                    <h2 class="fw-bold">@Model.TotalBranches</h2>
                    <p class="text-muted mb-0">Campus branches</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-5">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h4 class="mb-3">Quick Access</h4>
                <div class="d-flex flex-wrap gap-2">
                    <a asp-controller="Students" asp-action="Index" class="btn btn-outline-primary">Students</a>
                    <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-success">Courses</a>
                    <a asp-controller="Lecturers" asp-action="Index" class="btn btn-outline-warning">Lecturers</a>
                    <a asp-controller="Branches" asp-action="Index" class="btn btn-outline-danger">Branches</a>
                </div>
            </div>
        </div>
    </div>
</div>