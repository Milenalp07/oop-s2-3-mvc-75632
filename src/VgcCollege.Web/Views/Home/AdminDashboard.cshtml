@model VgcCollege.Web.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="p-4 mb-4 bg-light border rounded-3 shadow-sm">
    <h1 class="display-5 fw-bold">VgcCollege Dashboard</h1>
    <p class="lead">Welcome to the academic management system. Use the dashboard below to access the main sections of the application.</p>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h3>Students</h3>
                <h2 class="text-primary">@Model.TotalStudents</h2>
                <p>Manage student profiles and records.</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h3>Courses</h3>
                <h2 class="text-success">@Model.TotalCourses</h2>
                <p>View and manage all courses.</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h3>Lecturers</h3>
                <h2 class="text-warning">@Model.TotalLecturers</h2>
                <p>Manage faculty profiles and staff data.</p>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h3>Branches</h3>
                <h2 class="text-danger">@Model.TotalBranches</h2>
                <p>View and manage campus branches.</p>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2>Quick Access</h2>
                <p>Use the shortcuts below to quickly navigate to the most important areas of the system.</p>

                <a asp-controller="StudentProfiles" asp-action="Index" class="btn btn-outline-primary me-2 mb-2">Students</a>
                <a asp-controller="Courses" asp-action="Index" class="btn btn-outline-success me-2 mb-2">Courses</a>
                <a asp-controller="CourseEnrolments" asp-action="Index" class="btn btn-outline-secondary me-2 mb-2">Enrolments</a>
                <a asp-controller="FacultyProfiles" asp-action="Index" class="btn btn-outline-warning me-2 mb-2">Lecturers</a>
                <a asp-controller="Branches" asp-action="Index" class="btn btn-outline-danger me-2 mb-2">Branches</a>
                <a asp-controller="AttendanceRecords" asp-action="Index" class="btn btn-outline-dark me-2 mb-2">Attendance</a>
                <a asp-controller="AssignmentResults" asp-action="Index" class="btn btn-outline-info me-2 mb-2">Results</a>
                <a asp-controller="Exams" asp-action="Index" class="btn btn-outline-primary me-2 mb-2">Exams</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h2>System Overview</h2>
                <table class="table">
                    <tr>
                        <td>Total Students</td>
                        <td class="fw-bold text-end">@Model.TotalStudents</td>
                    </tr>
                    <tr>
                        <td>Total Courses</td>
                        <td class="fw-bold text-end">@Model.TotalCourses</td>
                    </tr>
                    <tr>
                        <td>Total Lecturers</td>
                        <td class="fw-bold text-end">@Model.TotalLecturers</td>
                    </tr>
                    <tr>
                        <td>Total Branches</td>
                        <td class="fw-bold text-end">@Model.TotalBranches</td>
                    </tr>
                </table>
            </div>
        </div>
    </div>
</div>